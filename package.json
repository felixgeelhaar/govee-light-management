{
  "name": "govee-light-management",
  "version": "2.3.1",
  "description": "Enterprise-grade Stream Deck plugin for managing Govee lights with advanced group functionality",
  "main": "com.felixgeelhaar.govee-light-management.sdPlugin/bin/plugin.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "dev": "node scripts/watch-backend.js",
    "streamdeck:dev": "streamdeck dev",
    "streamdeck:link": "streamdeck link com.felixgeelhaar.govee-light-management.sdPlugin",
    "streamdeck:restart": "streamdeck restart com.felixgeelhaar.govee-light-management",
    "streamdeck:validate": "streamdeck validate com.felixgeelhaar.govee-light-management.sdPlugin",
    "streamdeck:pack": "streamdeck pack com.felixgeelhaar.govee-light-management.sdPlugin --output dist/",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "dev:build": "npm run build && node scripts/patch-dev-build.mjs",
    "dev:link": "npm run dev:build && streamdeck link com.felixgeelhaar.govee-light-management.dev.sdPlugin",
    "dev:restart": "streamdeck restart com.felixgeelhaar.govee-light-management.dev",
    "dev:unlink": "streamdeck unlink com.felixgeelhaar.govee-light-management.dev",
    "prod:pack": "npm run build && streamdeck pack com.felixgeelhaar.govee-light-management.sdPlugin --output dist/"
  },
  "type": "module",
  "devDependencies": {
    "@elgato/cli": "^1.7.3",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "25.0.3",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "chokidar": "5.0.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "9.1.7",
    "jsdom": "27.4.0",
    "lint-staged": "16.2.7",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "rollup": "^4.60.1",
    "tslib": "2.8.1",
    "typescript": "^5.5.4",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.4",
    "@felixgeelhaar/govee-api-client": "^3.3.0",
    "zod": "4.3.5"
  },
  "overrides": {
    "glob": "^10.5.0",
    "js-yaml": "^4.1.1",
    "tar": "^7.5.2",
    "minimatch": "^9.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/felixgeelhaar/govee-light-management.git"
  },
  "keywords": [
    "streamdeck",
    "govee",
    "smart-lights",
    "automation",
    "elgato"
  ],
  "author": "Felix Geelhaar",
  "license": "MIT",
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  }
}
