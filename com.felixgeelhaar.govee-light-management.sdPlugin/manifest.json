      "UUID": "com.felixgeelhaar.govee-light-management.brightness",
      "Icon": "imgs/actions/brightness/icon",
      "Tooltip": "Set the brightness of a light or group — drag onto a key to set a fixed value, drag onto a Stream Deck+ dial to rotate-adjust",
